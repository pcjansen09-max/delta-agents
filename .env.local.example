# DeltaAgents — local dev environment template
# Kopieer naar .env.local en vul echte waarden in. NIET committen.
# In Vercel: configureer via dashboard onder Project Settings > Environment Variables.

# ── Anthropic Claude (agent reasoning + audio transcription) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (database, auth, storage) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Service role key is server-side only; gebruik nooit in client code.

# ── Moneybird OAuth (factuur-creatie) ──
MONEYBIRD_CLIENT_ID=your-client-id
MONEYBIRD_CLIENT_SECRET=your-client-secret
# Redirect URI in Moneybird app: https://deltaagents.nl/api/moneybird/callback

# ── WhatsApp Business Platform (Meta direct) ──
# Beschikbaar pas na Meta business verification (week 3-4)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=deltaagents-pick-something-random
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Token encryption (OAuth tokens at rest) ──
# Genereer met: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── Voyage AI (embeddings voor Wisdom Layer rule retrieval) ──
# Gratis tier op voyageai.com — voyage-3-lite model
VOYAGE_API_KEY=

# ── WhatsApp App Secret (voor webhook signature verification) ──
# Te vinden in Meta App Dashboard -> Basic Settings -> App Secret
WHATSAPP_APP_SECRET=

# ── Site URL (voor OAuth redirects) ──
NEXT_PUBLIC_SITE_URL=https://deltaagents.nl

# ── Web3Forms (waitlist email forwarding — gedeeld met delta-design.nl) ──
WEB3FORMS_ACCESS_KEY=84ab51cd-7f92-4ec1-9b77-492755ff5167

# ── Feature flags (voor MVP development) ──
# Stel op 'true' om dev-routes (onboarding, dashboard) te bezoeken zonder
# productie-redirect. Op productie: laat leeg of zet op 'false'.
NEXT_PUBLIC_DEV_ROUTES=false
